---
import { Image } from "astro:assets";
import ImpactStackLogo from "@/assets/images/ingra_logo_pink_nopadding.png";
---

<section class="impact-stack-plug" aria-label="Impact Stack">
	<a href="https://www.impact-stack.org" aria-label="Visit Impact Stack">
		<Image class="impact-stack-logo" src={ImpactStackLogo} alt="Impact Stack" priority />
	</a>
	<p><slot /></p>
</section>

<style>
	.impact-stack-plug {
		display: flex;
		align-items: center;
		gap: 1rem;
		max-width: 36rem;
		margin-top: 1.5rem;
		margin-bottom: 1.5rem;
		padding: 0.875rem 1rem;
		background: #f8f9fa;
		border: 1px solid #e9ecef;
		border-radius: 6px;
		color: #343433;
		font-size: 0.9375rem;
		line-height: 1.45;
	}

	.impact-stack-plug a:has(> .impact-stack-logo) {
		border-bottom: 0;
		box-shadow: none;
		flex: 0 0 auto;
	}

	.impact-stack-logo {
		width: 6rem;
		max-width: 100%;
	}

	.impact-stack-plug p {
		margin-bottom: 0;
	}
</style>
