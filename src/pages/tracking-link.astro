---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TrackingLinkIsland from "@/islands/tracking-link.svelte";
import Feedback from "@/components/Feedback.astro";
import ImpactStackPlug from "@/components/ImpactStackPlug.astro";
---

<BaseLayout
	title="Tracking Link Generator"
	description="Create UTM tracking links"
	socialImageFilename="tracking-link.png"
>
	<div id="toolDescription">
		<p>
			Create UTM tracking links to help you see how your supporters arrived on your action pages
		</p>
	</div>

	<ImpactStackPlug>
		Tracking link generator brought to you by campaigning and fundraising platform <a
			href="https://www.impact-stack.org">Impact Stack</a
		>. Use it to create UTM links for campaign emails, ads, and social posts.
	</ImpactStackPlug>

	<div id="islandWrapper" class="mt-6">
		<TrackingLinkIsland client:load />
	</div>
	<Feedback />
</BaseLayout>

<style>
	#toolDescription,
	#islandWrapper {
		max-width: 36rem;
	}

	div p {
		margin-bottom: 0;
	}
</style>
