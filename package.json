		"globals": "^16.0.0",
		"js-beautify": "^2.0.3",
		"prettier": "^3.9.4",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
